# Trabajo Final Integrador - Laboratorio de Python
# Escenario 12: Gestión de supermercado

productos = {
    1: {"nombre": "Arroz 1kg", "precio": 1800.0, "vendidos": 0},
    2: {"nombre": "Leche 1L", "precio": 1200.0, "vendidos": 0},
    3: {"nombre": "Fideos 500g", "precio": 1500.0, "vendidos": 0},
    4: {"nombre": "Aceite 900ml", "precio": 3200.0, "vendidos": 0},
    5: {"nombre": "Azúcar 1kg", "precio": 1700.0, "vendidos": 0},
    6: {"nombre": "Yerba 1kg", "precio": 4200.0, "vendidos": 0}
}

clientes_atendidos = 0
total_recaudado = 0.0
numero_venta = 1

# En esta lista se guarda el detalle de cada venta realizada.
historial_ventas = []


def mostrar_menu():
    """Muestra el menú principal del sistema."""
    print("\n" + "=" * 50)
    print("          SISTEMA DE CAJA - SUPERMERCADO")
    print("=" * 50)
    print("1. Cargar nueva venta")
    print("2. Ver estadísticas")
    print("3. Ver catálogo")
    print("0. Salir")
    print("=" * 50)


def leer_entero(mensaje):
    """
    Lee un número entero validado.
    Evita que el programa falle si el usuario ingresa letras.
    """
    while True:
        try:
            valor = int(input(mensaje))
            return valor
        except ValueError:
            print("Error: debe ingresar un número entero.")


def mostrar_catalogo():
    """
    Muestra el catálogo de productos.
    La pantalla queda abierta hasta que el usuario ingrese 0.
    """
    opcion = -1

    while opcion != 0:
        print("\n" + "-" * 50)
        print("CATÁLOGO DE PRODUCTOS")
        print("-" * 50)
        print(f"{'Código':<8}{'Producto':<22}{'Precio':>12}")
        print("-" * 50)

        for codigo, datos in productos.items():
            print(
                f"{codigo:<8}"
                f"{datos['nombre']:<22}"
                f"${datos['precio']:>11.2f}"
            )

        print("-" * 50)
        print("0. Volver al menú principal")

        opcion = leer_entero("Ingrese 0 para volver: ")

        if opcion != 0:
            print("Opción incorrecta. Para volver ingrese 0.")


def pedir_codigo_producto():
    """
    Pide el código del producto.
    El código 0 se usa para terminar la carga de productos.
    """
    while True:
        codigo = leer_entero("\nIngrese código de producto (0 para terminar): ")

        if codigo == 0:
            return codigo

        if codigo in productos:
            return codigo

        print("El código ingresado no existe. Intente nuevamente.")


def pedir_cantidad():
    """Pide una cantidad válida mayor a cero."""
    while True:
        cantidad = leer_entero("Ingrese cantidad: ")

        if cantidad > 0:
            return cantidad

        print("La cantidad debe ser mayor a cero.")


def agregar_al_carrito(carrito, codigo, cantidad):
    """
    Agrega un producto al carrito.
    Si ya estaba cargado, suma la nueva cantidad.
    """
    if codigo in carrito:
        carrito[codigo] += cantidad
    else:
        carrito[codigo] = cantidad


def calcular_subtotal(carrito):
    """Calcula el subtotal de la venta."""
    subtotal = 0.0

    for codigo, cantidad in carrito.items():
        subtotal += productos[codigo]["precio"] * cantidad

    return subtotal


def calcular_descuento(subtotal):
    """
    Aplica un 10% de descuento si el subtotal supera los $10.000.
    """
    if subtotal > 10000:
        descuento = subtotal * 0.10
    else:
        descuento = 0.0

    return descuento


def imprimir_ticket(carrito, subtotal, descuento, total_final):
    """Imprime un ticket prolijo por consola."""
    print("\n" + "=" * 60)
    print("                    SUPERMERCADO PYTHON")
    print("                       TICKET DE COMPRA")
    print("=" * 60)
    print(f"{'Producto':<22}{'Cant.':>8}{'Precio':>14}{'Total':>14}")
    print("-" * 60)

    for codigo, cantidad in carrito.items():
        nombre = productos[codigo]["nombre"]
        precio = productos[codigo]["precio"]
        total_producto = precio * cantidad

        print(
            f"{nombre:<22}"
            f"{cantidad:>8}"
            f"${precio:>13.2f}"
            f"${total_producto:>13.2f}"
        )

    print("-" * 60)
    print(f"{'Subtotal:':<45}${subtotal:>12.2f}")
    print(f"{'Descuento:':<45}${descuento:>12.2f}")
    print(f"{'Total final:':<45}${total_final:>12.2f}")
    print("=" * 60)
    print("                 Gracias por su compra")
    print("=" * 60)


def guardar_venta_en_historial(carrito, total_final):
    """
    Guarda el detalle de la venta en el historial.
    Esto permite ver después qué productos se compraron.
    """
    global numero_venta

    detalle = []

    for codigo, cantidad in carrito.items():
        detalle.append({
            "producto": productos[codigo]["nombre"],
            "cantidad": cantidad,
            "precio": productos[codigo]["precio"],
            "total_producto": productos[codigo]["precio"] * cantidad
        })

    venta = {
        "numero": numero_venta,
        "detalle": detalle,
        "total": total_final
    }

    historial_ventas.append(venta)
    numero_venta += 1


def actualizar_estadisticas(carrito, total_final):
    """
    Actualiza los acumuladores y contadores del sistema.
    """
    global clientes_atendidos
    global total_recaudado

    clientes_atendidos += 1
    total_recaudado += total_final

    for codigo, cantidad in carrito.items():
        productos[codigo]["vendidos"] += cantidad


def cargar_nueva_venta():
    """
    Permite cargar una nueva venta completa.
    El usuario puede ingresar varios productos hasta escribir 0.
    """
    carrito = {}

    print("\n" + "=" * 50)
    print("NUEVA VENTA")
    print("=" * 50)
    print("Productos disponibles:")

    for codigo, datos in productos.items():
        print(f"{codigo}. {datos['nombre']} - ${datos['precio']:.2f}")

    while True:
        codigo = pedir_codigo_producto()

        if codigo == 0:
            break

        cantidad = pedir_cantidad()
        agregar_al_carrito(carrito, codigo, cantidad)
        print("Producto agregado correctamente.")

    if len(carrito) == 0:
        print("\nNo se cargaron productos. Venta cancelada.")
        return

    subtotal = calcular_subtotal(carrito)
    descuento = calcular_descuento(subtotal)
    total_final = subtotal - descuento

    imprimir_ticket(carrito, subtotal, descuento, total_final)
    actualizar_estadisticas(carrito, total_final)
    guardar_venta_en_historial(carrito, total_final)


def obtener_producto_mas_vendido():
    """
    Calcula cuál fue el producto más vendido.
    """
    mayor_cantidad = 0
    nombre_producto = "No hubo ventas"

    for datos in productos.values():
        if datos["vendidos"] > mayor_cantidad:
            mayor_cantidad = datos["vendidos"]
            nombre_producto = datos["nombre"]

    if mayor_cantidad == 0:
        return "No hubo ventas"

    return f"{nombre_producto} ({mayor_cantidad} unidades)"


def mostrar_productos_vendidos():
    """
    Muestra cuánto se vendió de cada producto.
    """
    print("\nPRODUCTOS VENDIDOS")
    print("-" * 50)
    print(f"{'Producto':<25}{'Cantidad vendida':>18}")
    print("-" * 50)

    for datos in productos.values():
        print(f"{datos['nombre']:<25}{datos['vendidos']:>18}")

    print("-" * 50)


def mostrar_historial_ventas():
    """
    Muestra el detalle de cada venta realizada.
    """
    print("\nHISTORIAL DE VENTAS")
    print("-" * 50)

    if len(historial_ventas) == 0:
        print("Todavía no se realizaron ventas.")
        print("-" * 50)
        return

    for venta in historial_ventas:
        print(f"\nVenta N° {venta['numero']}")
        print("-" * 50)

        for item in venta["detalle"]:
            print(
                f"{item['producto']} - "
                f"Cantidad: {item['cantidad']} - "
                f"Total: ${item['total_producto']:.2f}"
            )

        print(f"Total de la venta: ${venta['total']:.2f}")


def mostrar_estadisticas():
    """
    Muestra las estadísticas generales.
    La pantalla queda abierta hasta que el usuario ingrese 0.
    """
    opcion = -1

    while opcion != 0:
        print("\n" + "=" * 55)
        print("                  ESTADÍSTICAS DEL DÍA")
        print("=" * 55)
        print(f"Clientes atendidos: {clientes_atendidos}")
        print(f"Total recaudado: ${total_recaudado:.2f}")
        print(f"Producto más vendido: {obtener_producto_mas_vendido()}")
        print("=" * 55)

        mostrar_productos_vendidos()
        mostrar_historial_ventas()

        print("\n0. Volver al menú principal")
        opcion = leer_entero("Ingrese 0 para volver: ")

        if opcion != 0:
            print("Opción incorrecta. Para volver ingrese 0.")


def main():
    """
    Función principal del programa.
    Mantiene el menú activo hasta que el usuario elige salir.
    """
    opcion = -1

    while opcion != 0:
        mostrar_menu()
        opcion = leer_entero("Seleccione una opción: ")

        if opcion == 1:
            cargar_nueva_venta()

        elif opcion == 2:
            mostrar_estadisticas()

        elif opcion == 3:
            mostrar_catalogo()

        elif opcion == 0:
            print("\nSistema finalizado correctamente.")

        else:
            print("Opción incorrecta. Intente nuevamente.")


main()
